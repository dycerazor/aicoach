rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROTOTYPE MODE SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model. Every piece of data is architected to 
     * be owned by a specific authenticated user. Authorization is handled primarily through 
     * hierarchical path-based checks, ensuring users can only access their own data tree.
     *
     * Data Structure:
     * The primary data organization is nested under the user's unique identifier: `/users/{userId}/...`. 
     * This structure naturally segments data, making security rules easier to reason about and 
     * preventing accidental data leakage between users.
     *
     * Key Security Decisions:
     * 1. Strict Ownership: All read and write operations require the user's UID to match the {userId} in the path.
     * 2. Path-Data Consistency: On creation, we enforce that internal document fields (like userId) 
     *    match the URL path. On update, these relational fields are made immutable.
     * 3. No Public Listing: There are no public collections. Users can only list documents within 
     *    their own subcollections.
     *
     * Denormalization for Authorization:
     * To ensure high performance and avoid costly `get()` calls in rules, the `userId` is 
     * denormalized into every `CoachingSession` document. This allows for immediate 
     * validation that the document being written belongs to the user specified in the path.
     *
     * Structural Segregation:
     * By nesting `coachingSessions` under a specific `userId`, we achieve structural segregation. 
     * This allows us to secure entire branches of the database with a single, high-level 
     * ownership check, ensuring users never see or modify sessions belonging to others.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is made by an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combines ownership check with a check that the document already exists. Useful for update/delete. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root user document. Allows users to manage their own profile.
     * @path /users/{userId}
     * @allow Authenticated user (create/get/update) where UID matches {userId}.
     * @deny Any user attempting to read or write to a different user's document.
     * @principle Self-creation and strict ownership of the user's root document.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      /**
       * @description Rules for coaching sessions. Each session is private to the owning user.
       * @path /users/{userId}/coachingSessions/{coachingSessionId}
       * @allow User 'abc' (create) to /users/abc/coachingSessions/session_123 if data.userId == 'abc'.
       * @deny User 'abc' (list) /users/xyz/coachingSessions.
       * @principle Enforces path-based ownership and validates relational integrity of the userId field.
       */
      match /coachingSessions/{coachingSessionId} {
        allow get, list: if isOwner(userId);
        
        // On Create: Ensure user owns the path AND the data matches the path
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == coachingSessionId;
        
        // On Update: Ensure user owns the document AND relational fields are immutable
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.id == resource.data.id;
        
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}