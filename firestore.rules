rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES DOCUMENTATION
     *
     * Core Philosophy:
     * This ruleset implements a strict hierarchical ownership model. All application data is 
     * logically and physically partitioned under a user's unique identifier (/users/{userId}).
     * This ensures that by default, data is private and accessible only to the originating user.
     *
     * Data Structure:
     * The hierarchy follows a User -> CoachingSession -> SessionTranscript -> TranscriptEntry 
     * nesting pattern. This structure mirrors the natural relationship of the data and 
     * facilitates efficient path-based authorization.
     *
     * Key Security Decisions:
     * 1. Path-Based Authorization: We rely primarily on the {userId} wildcard in the path 
     *    to verify ownership against the authenticated 'request.auth.uid'.
     * 2. Denormalization for Integrity: Relational fields (like userId and coachingSessionId) 
     *    are expected within document bodies. Rules enforce that these fields match the 
     *    path parameters during creation to maintain relational integrity.
     * 3. Prototyping Flexibility: While authorization is strictly enforced, the rules do 
     *    not validate specific data types or non-relational fields, allowing for rapid schema iteration.
     * 4. State Safety: Update and delete operations require the resource to exist and 
     *    ownership to be verified before proceeding.
     *
     * Structural Segregation:
     * All data is treated as private user content. There are no public collections 
     * defined in this IR.
     */

    // --- Helper Functions ---

    /** Checks if the request is made by a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user matches the provided userId from the path. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Verifies the document exists and the requester is the owner. Used for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for individual coaching sessions. Access is restricted to the session owner.
     * @path /users/{userId}/coachingSessions/{coachingSessionId}
     * @allow (create) User 'abc' creates a session at /users/abc/coachingSessions/session_123 where data.userId == 'abc'.
     * @deny (list) User 'abc' attempts to list sessions at /users/xyz/coachingSessions.
     * @principle Enforces strict path-based ownership and validates relational consistency on creation.
     */
    match /users/{userId}/coachingSessions/{coachingSessionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == coachingSessionId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for transcripts associated with a coaching session.
       * @path /users/{userId}/coachingSessions/{coachingSessionId}/sessionTranscripts/{sessionTranscriptId}
       * @allow (get) User 'abc' reads their own transcript.
       * @deny (update) User 'abc' attempts to change the 'userId' field of an existing transcript.
       * @principle Uses denormalized userId field to ensure authorization context remains consistent.
       */
      match /sessionTranscripts/{sessionTranscriptId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.coachingSessionId == coachingSessionId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for individual entries within a transcript.
         * @path /users/{userId}/coachingSessions/{coachingSessionId}/sessionTranscripts/{sessionTranscriptId}/transcriptEntries/{transcriptEntryId}
         * @allow (list) User 'abc' fetches all entries for their specific transcript.
         * @deny (create) User 'abc' attempts to create an entry under User 'xyz's path.
         * @principle Deeply nested ownership verification using path wildcards.
         */
        match /transcriptEntries/{transcriptEntryId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}