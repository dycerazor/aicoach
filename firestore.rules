rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AI Coach Connect: Security Rules Overview
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict Path-Based Ownership model. Security is derived from the
     * hierarchical structure of the data, ensuring that users can only access data nested 
     * under their own unique identifier.
     *
     * DATA STRUCTURE:
     * All application data is organized under the `/users/{userId}` root. This includes user 
     * profiles and their nested subcollection of `coaching_sessions`.
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: By using the UID in the document path, we avoid expensive
     *    `get()` lookups. Ownership is verified by comparing the path wildcard to `request.auth.uid`.
     * 2. Prototyping Flexibility: While authorization is strictly enforced (who can access what),
     *    data validation is limited to relational integrity (ensuring internal IDs match the path).
     *    This allows for rapid iteration of the data schema.
     * 3. No Public Access: There are no public collections. Authentication is required for all
     *    interactions with the database.
     * 4. Query Security: `list` operations are scoped strictly to the authenticated user's own path.
     */

    // --- Helper Functions ---

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Validates that the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Combines ownership check with a check for the document's existence.
     * Used for update and delete operations to prevent actions on non-existent data.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Allows users to manage their own profile.
     * @path /users/{userId}
     * @allow (create) if auth.uid matches path userId.
     * @deny (list) if trying to list all users in the system.
     * @principle Pattern 1 (Ownership) & Pattern 4 (Self-Creation).
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      /**
       * @description Records of individual coaching sessions. Scoped to the parent user.
       * @path /users/{userId}/coaching_sessions/{sessionId}
       * @allow (list) a user fetching their own session history.
       * @deny (update) if the session document does not exist or belongs to another user.
       * @principle Hierarchical ownership ensures Authorization Independence.
       */
      match /coaching_sessions/{sessionId} {
        allow get, list: if isOwner(userId);
        
        // On create, we enforce that if a userId is provided in the body, it must match the path.
        allow create: if isOwner(userId) && 
          (!('userId' in request.resource.data) || request.resource.data.userId == userId);
        
        // On update, we ensure the userId field (relational link) cannot be changed.
        allow update: if isExistingOwner(userId) && 
          (!('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId);
          
        allow delete: if isExistingOwner(userId);
      }
    }

    // --- Default Deny ---
    // Explicitly deny any access to collections not defined above.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}